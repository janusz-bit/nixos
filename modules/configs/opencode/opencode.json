{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/kimi-k2.6:cloud",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "caveman-opencode-plugin",
    "opencode-skillful"
  ],
  "permission": {
    "websearch": "allow"
  },
  "mcp": {
    "web_search_and_fetch": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "/etc/opencode/web-search-mcp.py"
      ],
      "enabled": true
    }
  }
}
